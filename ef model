using FastBite.Data;
using FastBite.Models;
using Microsoft.AspNetCore.Mvc;
using System.Linq;

namespace FastBite.Controllers
{
    public class CategoryController : Controller
    {
        private readonly ApplicationDbContext _db;

        public CategoryController(ApplicationDbContext db)
        {
            _db = db;
        }

        public IActionResult Index()
        {
            return View(_db.Category.ToList());
        }

        public IActionResult Create()
        {
            return View();
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Create(Category obj)
        {
            if (ModelState.IsValid)
            {
                _db.Category.Add(obj);
                _db.SaveChanges();
                return RedirectToAction(nameof(Index));
            }

            return View(obj);
        }

        public IActionResult Edit(int id)
        {
            var obj = _db.Category.Find(id);

            if (obj == null)
                return NotFound();

            return View(obj);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Edit(Category obj)
        {
            if (ModelState.IsValid)
            {
                _db.Category.Update(obj);
                _db.SaveChanges();
                return RedirectToAction(nameof(Index));
            }

            return View(obj);
        }

        public IActionResult Delete(int id)
        {
            var obj = _db.Category.Find(id);

            if (obj == null)
                return NotFound();

            return View(obj);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Delete(Category obj)
        {
            _db.Category.Remove(obj);
            _db.SaveChanges();

            return RedirectToAction(nameof(Index));
        }
    }
}

////////////////////////////////////////////////////////////////Controllers/SubCategoryController.cs

using FastBite.Data;
using FastBite.Models;
using FastBite.Models.ViewModels;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using System.Collections.Generic;
using System.Linq;

namespace FastBite.Controllers
{
    public class SubCategoryController : Controller
    {
        private readonly ApplicationDbContext _db;

        public SubCategoryController(ApplicationDbContext db)
        {
            _db = db;
        }

        public IActionResult Index()
        {
            var objList = _db.SubCategory
                             .Include(x => x.category)
                             .ToList();

            return View(objList);
        }

        public IActionResult Create()
        {
            CategoryAndSubCategoryModel obj = new CategoryAndSubCategoryModel
            {
                categoryList = _db.Category.ToList(),
                subCategory = new SubCategory(),
                subCategoryList = new List<string>()
            };

            return View(obj);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Create(CategoryAndSubCategoryModel obj)
        {
            if (ModelState.IsValid)
            {
                _db.SubCategory.Add(obj.subCategory);
                _db.SaveChanges();

                return RedirectToAction(nameof(Index));
            }

            obj.categoryList = _db.Category.ToList();

            return View(obj);
        }

        public IActionResult Edit(int id)
        {
            var subCat = _db.SubCategory.Find(id);

            if (subCat == null)
                return NotFound();

            CategoryAndSubCategoryModel obj = new CategoryAndSubCategoryModel
            {
                subCategory = subCat,
                categoryList = _db.Category.ToList()
            };

            return View(obj);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Edit(CategoryAndSubCategoryModel obj)
        {
            if (ModelState.IsValid)
            {
                _db.SubCategory.Update(obj.subCategory);
                _db.SaveChanges();

                return RedirectToAction(nameof(Index));
            }

            obj.categoryList = _db.Category.ToList();

            return View(obj);
        }

        public IActionResult Delete(int id)
        {
            var obj = _db.SubCategory.Find(id);

            if (obj == null)
                return NotFound();

            return View(obj);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult Delete(SubCategory obj)
        {
            _db.SubCategory.Remove(obj);
            _db.SaveChanges();

            return RedirectToAction(nameof(Index));
        }
    }
}

