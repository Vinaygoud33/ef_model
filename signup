import React, { useState } from "react";
import MediLogo from "../images/Medi-logo.png";
import {
  Collapse,
  Navbar,
  NavbarToggler,
  NavbarBrand,
  Nav,
  UncontrolledDropdown,
  DropdownToggle,
  DropdownMenu,
  DropdownItem
} from "reactstrap";
import { NavLink as ReactLink } from "react-router-dom";

const Example = props => {
  const [isOpen, setIsOpen] = useState(false);

  const toggle = () => setIsOpen(!isOpen);

  const handleLogout = () => {
    localStorage.removeItem("token");
    localStorage.removeItem("userId");
    window.location.hash = "/sign-in";
  };

  return (
    <div>
      <Navbar style={{ backgroundColor: "#D3D3D3" }} light expand="md">
        <NavbarBrand tag={ReactLink} to="/allPatients">
          <img src={MediLogo} style={{ width: 100, marginTop: -7 }} />
        </NavbarBrand>

        <NavbarToggler onClick={toggle} />
        <Collapse isOpen={isOpen} navbar>
          <Nav className="mr-auto" navbar>

            <UncontrolledDropdown nav inNavbar>
              <DropdownToggle nav caret>
                Patient
              </DropdownToggle>
              <DropdownMenu right>
                <DropdownItem tag={ReactLink} to="/addPatient">
                  Add Patient
                </DropdownItem>
                <DropdownItem tag={ReactLink} to="/allPatients">
                  All Patient
                </DropdownItem>
              </DropdownMenu>
            </UncontrolledDropdown>

            <UncontrolledDropdown nav inNavbar>
              <DropdownToggle nav caret>
                Appointments
              </DropdownToggle>
              <DropdownMenu right>
                <DropdownItem tag={ReactLink} to="/bookAppointment">
                  Book Appointment
                </DropdownItem>
                <DropdownItem tag={ReactLink} to="/allAppointments">
                  All Appointments
                </DropdownItem>
              </DropdownMenu>
            </UncontrolledDropdown>

            <UncontrolledDropdown nav inNavbar>
              <DropdownToggle nav caret>
                User
              </DropdownToggle>
              <DropdownMenu right>
                <DropdownItem tag={ReactLink} to="/viewProfile">
                  View Profile
                </DropdownItem>
                <DropdownItem tag={ReactLink} to="/editProfile">
                  Edit Profile
                </DropdownItem>
                <DropdownItem onClick={handleLogout}>
                  Logout
                </DropdownItem>
              </DropdownMenu>
            </UncontrolledDropdown>
          </Nav>
        </Collapse>
      </Navbar>
    </div>
  );
};

export default Example;



